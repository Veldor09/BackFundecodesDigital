# =============================================================
#  Backend Fundecodes — Variables de producción
#  Copiar a .env.back (en /opt/fundecodes/) y rellenar todo.
#  NO versionar este archivo con valores reales.
# =============================================================

# ---- App ----
NODE_ENV=production
PORT=4000

# ---- Base de datos (Postgres en docker-compose) ----
# Para el stack unificado se sobreescribe desde docker-compose.prod.yml,
# pero se deja aquí por si se usa fuera de compose.
DATABASE_URL=postgresql://fundecodes:CAMBIAR_PASSWORD@db:5432/fundecodes_prod?schema=public

# ---- JWT ----
# Genera con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_DE_AL_MENOS_32_CARACTERES_AAA
JWT_EXPIRES=1d

# ---- CORS ----
# Dominio público del frontend (para CORS_ALLOWED_ORIGINS si se usa la lista)
FRONTEND_URL=https://tu-dominio.com
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ---- Bcrypt ----
BCRYPT_COST=12

# ---- Uploads ----
FILE_MAX_SIZE_MB=50
UPLOADS_DIR=/app/uploads

# ---- Mailjet ----
MJ_APIKEY_PUBLIC=TU_API_KEY_PUBLICA
MJ_APIKEY_PRIVATE=TU_API_KEY_PRIVADA
MJ_SENDER_EMAIL=no-reply@tu-dominio.com
MJ_SENDER_NAME=Fundecodes Digital

# ---- Proxy / HTTPS ----
# Nginx va delante → confiamos en X-Forwarded-*
TRUST_PROXY=1

# ---- Swagger / Docs (OPCIONAL) ----
# Déjalo en false en producción salvo que haya autenticación adicional.
SWAGGER_ENABLED=false

# ---- Body limits (alineado con Nginx) ----
BODY_LIMIT_JSON=10mb
BODY_LIMIT_URLENCODED=10mb
