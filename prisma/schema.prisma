generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoTransaccion {
  ingreso
  egreso
}

// ===== Area — entidad pivote que agrupa proyectos, programas y cuenta =====
// Una área representa una unidad operativa de Fundecodes (ej. "Camaronal").
// Puede tener proyectos y programas asociados (opcionales), y está enlazada
// 1:1 con una Cuenta para el flujo de contabilidad.
model Area {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  proyectos       Project[]              @relation("AreaProyectos")
  programas       ProgramaVoluntariado[] @relation("AreaProgramas")
  cuenta          Cuenta?                @relation("AreaCuenta")
  colaboradores   Collaborator[]         @relation("AreaColaboradores")
  billingRequests BillingRequest[]       @relation("AreaBillingRequests")
  solicitudes     SolicitudCompra[]      @relation("AreaSolicitudes")

  @@index([activa])
  @@map("area")
}

// ===== NUEVO: Cuenta — contenedor financiero del módulo de Contabilidad =====
// Los proyectos y programas pueden estar (o no) bajo una cuenta. La cuenta no
// guarda saldos ni presupuestos propios: sus totales se CALCULAN al vuelo a
// partir de los proyectos/programas que contiene + las transacciones cuyo
// snapshot `cuentaId` apunte aquí (esto permite mover un proyecto a otra
// cuenta sin perder la historia: las transacciones viejas siguen pertene-
// ciendo a esta cuenta, las nuevas se irán a la cuenta destino).
model Cuenta {
  id          Int       @id @default(autoincrement())
  nombre      String
  codigo      String    @unique         // consecutivo bancario / identificador único
  descripcion String?
  monedaBase  Currency  @default(CRC)
  activa      Boolean   @default(true)

  // Área a la que pertenece esta cuenta (1:1, nullable hasta asignar)
  areaId      Int?      @unique
  area        Area?     @relation("AreaCuenta", fields: [areaId], references: [id], onDelete: SetNull)

  proyectos    Project[]
  programas    ProgramaVoluntariado[]
  transacciones Transaccion[]
  billingRequests BillingRequest[]
  payments        Payment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([activa])
}

// ===== NUEVO: ColaboradorAsignacion =====
// Un colaborador (en particular los de tipo `colaboradorfactura`) solo puede
// crear solicitudes para proyectos/programas a los que está asignado. Cada
// fila representa una asignación; un colaborador puede tener varias.
model ColaboradorAsignacion {
  id             Int       @id @default(autoincrement())
  collaboratorId Int
  projectId      Int?
  programaId     Int?
  createdAt      DateTime  @default(now())

  collaborator Collaborator           @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  project      Project?               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  programa     ProgramaVoluntariado?  @relation(fields: [programaId], references: [id], onDelete: Cascade)

  // Cada par colaborador↔destino solo puede existir una vez.
  @@unique([collaboratorId, projectId])
  @@unique([collaboratorId, programaId])
  @@index([collaboratorId])
  @@index([projectId])
  @@index([programaId])
}

model Project {
  id          Int                @id @default(autoincrement())
  title       String
  slug        String             @unique
  summary     String?
  content     String?
  coverUrl    String?
  published   Boolean            @default(false)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  area        String
  category    String
  place       String
  status      ProjectStatus      @default(EN_PROCESO)
  documents   ProjectDocument[]
  images      ProjectImage[]

  // === Área organizacional ===
  // Área de Fundecodes a la que pertenece este proyecto (nullable).
  areaId              Int?
  areaOrg             Area?    @relation("AreaProyectos", fields: [areaId], references: [id], onDelete: SetNull)

  // === Contabilidad ===
  // Cuenta a la que pertenece actualmente (nullable: puede existir sin cuenta).
  cuentaId            Int?
  cuenta              Cuenta?  @relation(fields: [cuentaId], references: [id], onDelete: SetNull)
  // Presupuesto TOTAL asignado en su cuenta actual. Se reasigna si cambia de
  // cuenta. El ejecutado NO se almacena: se calcula sumando transacciones
  // donde `transaccion.cuentaId = project.cuentaId` y `projectId = project.id`.
  presupuestoTotal    Decimal  @default(0) @db.Decimal(16, 2)
  monedaPresupuesto   Currency @default(CRC)

  presupuestos        Presupuesto[]
  transacciones       Transaccion[]
  documentosContables DocumentoContable[]

  billingRequests    BillingRequest[]
  billingInvoices    BillingInvoice[]
  programAllocations ProgramAllocation[]
  payments           Payment[]
  receipts           Receipt[]

  // Solicitudes de compra que apuntan a este proyecto.
  solicitudes        SolicitudCompra[]   @relation("ProjectSolicitudes")

  // Colaboradores asignados a este proyecto.
  asignaciones       ColaboradorAsignacion[]

  @@unique([title, place, area])
  @@index([status])
  @@index([updatedAt])
  @@index([cuentaId])
}

model ProjectImage {
  id        Int      @id @default(autoincrement())
  projectId Int
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([order])
}

model ProjectDocument {
  id        Int      @id @default(autoincrement())
  projectId Int
  url       String
  name      String
  mimeType  String?
  createdAt DateTime @default(now())
  size      Int?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model News {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String?
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model VolunteerForm {
  id             Int      @id @default(autoincrement())
  nombre         String
  email          String
  telefono       String
  disponibilidad String
  mensaje        String
  createdAt      DateTime @default(now())
}

model InformationalPage {
  id            String   @id @default("default")
  vision        Json
  mission       Json
  collaborators Json
  comments      Json
  updatedAt     DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  approved  Boolean  @default(false)

  roles              UserRole[]
  emailLogs          EmailLog[]
  passwordChangeLogs PasswordChangeLog[]
  auditorias         Auditoria[]

  solicitudHistorial SolicitudHistorial[]
  solicitudes        SolicitudCompra[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       UserRole[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  description String?
  roles       Role[]  @relation("PermissionToRole")
}

model UserRole {
  id     Int @id @default(autoincrement())
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Collaborator {
  id                    Int               @id @default(autoincrement())
  nombreCompleto        String            @map("nombre_completo")
  correo                String            @unique @db.VarChar(160)
  cedula                String?           @unique @db.VarChar(25)
  fechaNacimiento       DateTime?         @map("fecha_nacimiento")
  telefono              String?           @db.VarChar(25)
  rol                   ColaboradorRol    @default(colaboradorproyecto)
  /// Roles adicionales del colaborador (multi-rol). El campo `rol` sigue siendo
  /// el rol primario; este array lo complementa.
  roles                 ColaboradorRol[]  @default([])
  passwordHash          String            @map("password_hash") @db.VarChar(255)
  estado                ColaboradorEstado @default(ACTIVO)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  passwordUpdatedAt     DateTime?         @map("password_updated_at")
  tempPasswordExpiresAt DateTime?         @map("temp_password_expires_at")

  // Área a la que pertenece (solo aplica a roles externos de área)
  areaId      Int?
  areaOrg     Area?    @relation("AreaColaboradores", fields: [areaId], references: [id], onDelete: SetNull)

  // Asignaciones a proyectos/programas (solo relevante para colaboradorfactura)
  asignaciones ColaboradorAsignacion[]

  @@index([areaId])
  @@map("colaborador")
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  template  String?
  payload   Json?
  status    String
  attempt   Int      @default(0)
  error     String?  @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Voluntario {
  id           Int       @id @default(autoincrement())
  nombre       String                          // Nombre completo
  nacionalidad String?                         // País de origen
  fechaEntrada DateTime  @map("fecha_entrada") // Fecha de inicio
  fechaSalida  DateTime? @map("fecha_salida")  // Fecha de salida; cron elimina al día siguiente
  ong          String?                         // ONG u organización de origen

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Campos legados (nullable; datos existentes son test data)
  tipoDocumento   String?           @map("tipo_documento")
  numeroDocumento String?           @unique @map("numero_documento") @db.VarChar(25)
  nombreCompleto  String?           @map("nombre_completo")
  email           String?           @unique @db.VarChar(160)
  telefono        String?           @db.VarChar(25)
  fechaNacimiento DateTime?         @map("fecha_nacimiento")
  fechaIngreso    DateTime?         @default(now()) @map("fecha_ingreso")
  estado          ColaboradorEstado? @default(ACTIVO)

  programas ProgramaVoluntariadoAsignacion[]
  sanciones Sancion[]

  @@index([fechaSalida])
  @@map("voluntario")
}

enum ProjectStatus {
  EN_PROCESO
  FINALIZADO
  PAUSADO
}


enum ColaboradorRol {
  admin
  colaboradorfactura
  colaboradorvoluntariado
  colaboradorproyecto
  colaboradorcontabilidad
  colaboradorvisitacion          // Registra y gestiona visitaciones
  // Roles externos (personas de las áreas con acceso limitado al sistema)
  colaboradorsolicitante         // Crea solicitudes de factura; solo ve las suyas
  colaboradorvoluntariadoexterno // Registra y gestiona voluntarios de su área
}


enum ColaboradorEstado {
  ACTIVO
  INACTIVO
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum PasswordChangeType {
  RESET
  MANUAL
  INVITE_SET
}

model PasswordChangeLog {
  id        Int                @id @default(autoincrement())
  userId    Int
  user      User               @relation(fields: [userId], references: [id])
  ip        String?
  type      PasswordChangeType @default(RESET)
  createdAt DateTime           @default(now())

  @@index([userId, createdAt])
}

enum VoluntariadoOrigen {
  CUENTA_PROPIA
  INTERMEDIARIO
}

model ProgramaVoluntariado {
  id                  Int                              @id @default(autoincrement())
  nombre              String
  descripcion         String?
  lugar               String
  limiteParticipantes Int                              @default(0)
  imagenUrl           String?                          @map("imagen_url")
  imagenKey           String?                          @map("imagen_key")

  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt

  // === Área organizacional ===
  areaId               Int?
  areaOrg              Area?    @relation("AreaProgramas", fields: [areaId], references: [id], onDelete: SetNull)

  // === Contabilidad ===
  // Mismo tratamiento que Project: puede existir sin cuenta y, al asignarse,
  // su presupuesto vive en la cuenta actual. Histórico de transacciones se
  // queda en la cuenta donde se generaron (via Transaccion.cuentaId).
  cuentaId             Int?
  cuenta               Cuenta?  @relation(fields: [cuentaId], references: [id], onDelete: SetNull)
  presupuestoTotal     Decimal  @default(0) @db.Decimal(16, 2)
  monedaPresupuesto    Currency @default(CRC)

  // Relación con voluntarios (vía tabla intermedia)
  voluntarios         ProgramaVoluntariadoAsignacion[]

  // Solicitudes de compra que apuntan a este programa.
  solicitudes         SolicitudCompra[]

  // Movimientos financieros del programa.
  transacciones       Transaccion[]
  billingRequests     BillingRequest[]
  payments            Payment[]

  // Colaboradores asignados a este programa.
  asignaciones        ColaboradorAsignacion[]

  @@map("programa_voluntariado")
  @@index([nombre])
  @@index([cuentaId])
}


model ProgramaVoluntariadoAsignacion {
  programaId   Int
  voluntarioId Int

  pagoRealizado Boolean            @default(false) @map("pago_realizado")
  origen        VoluntariadoOrigen @default(CUENTA_PROPIA)
  intermediario String?            @db.VarChar(160) // empresa o intermediario (si aplica)

  fechaEntrada DateTime  @map("fecha_entrada")
  fechaSalida  DateTime? @map("fecha_salida")
  horasTotales Int       @default(0) @map("horas_totales")

  assignedAt   DateTime  @default(now()) @map("assigned_at")

  programa   ProgramaVoluntariado @relation(fields: [programaId], references: [id], onDelete: Cascade)
  voluntario Voluntario           @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@id([programaId, voluntarioId])
  @@index([voluntarioId])
  @@index([programaId])
  @@map("programa_voluntariado_asignacion")
}

enum SancionTipo {
  LEVE
  GRAVE
  MUY_GRAVE
  EXTREMADAMENTE_GRAVE
}

enum SancionEstado {
  ACTIVA
  EXPIRADA
  REVOCADA
}

model Sancion {
  id               Int           @id @default(autoincrement())
  voluntarioId     Int
  tipo             SancionTipo
  motivo           String
  descripcion      String?
  fechaInicio      DateTime
  fechaVencimiento DateTime?
  estado           SancionEstado @default(ACTIVA)
  creadaPor        String?
  revocadaPor      String?
  fechaRevocacion  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  voluntario Voluntario @relation(fields: [voluntarioId], references: [id])

  @@index([voluntarioId])
  @@index([estado])
}

enum EstadoContadora {
  PENDIENTE
  VALIDADA
  DEVUELTA
}

enum EstadoDirector {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoOrigenSolicitud {
  PROGRAMA
  PROYECTO
}

model SolicitudCompra {
  id                  Int                  @id @default(autoincrement())
  titulo              String
  descripcion         String
  archivos            String[]
  estado              String               @default("PENDIENTE")
  estadoContadora     EstadoContadora      @default(PENDIENTE)
  estadoDirector      EstadoDirector       @default(PENDIENTE)
  comentarioContadora String?
  comentarioDirector  String?
  usuarioId           Int?
  usuario             User?                @relation(fields: [usuarioId], references: [id])

  // Monto solicitado. Nullable para no romper solicitudes existentes;
  // el FE/back valida que sea obligatorio en nuevas solicitudes.
  monto               Decimal?             @db.Decimal(16, 2)

  // Destino legacy (campos conservados para histórico).
  tipoOrigen          TipoOrigenSolicitud?
  programaId          Int?
  programa            ProgramaVoluntariado? @relation(fields: [programaId], references: [id])
  projectId           Int?
  project             Project?             @relation(fields: [projectId], references: [id], name: "ProjectSolicitudes")

  // Nuevo flujo basado en Área.
  areaId              Int?
  areaOrg             Area?               @relation("AreaSolicitudes", fields: [areaId], references: [id])

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  historial           SolicitudHistorial[]

  @@index([programaId])
  @@index([projectId])
  @@index([areaId])
  @@index([usuarioId])
}

model SolicitudHistorial {
  id             Int      @id @default(autoincrement())
  solicitudId    Int
  estadoAnterior String
  estadoNuevo    String
  createdAt      DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  solicitud SolicitudCompra @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
}

model Presupuesto {
  id             String   @id @default(cuid())
  projectId      Int
  proyecto       String // título legible del proyecto
  mes            Int // 1..12
  anio           Int
  montoAsignado  Decimal  @db.Decimal(16, 2)
  montoEjecutado Decimal  @db.Decimal(16, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, anio, mes])
}

// ===== Transaccion (polimorfa: Project XOR Programa) =====
// Reglas:
//   • Exactamente UNO de (projectId, programaId) debe estar set — el back lo
//     valida en TransaccionesService.create.
//   • `cuentaId` es un SNAPSHOT de la cuenta del destino al momento de crear
//     la transacción. Si el proyecto/programa cambia de cuenta después, esta
//     transacción NO se mueve: permanece imputada a la cuenta original. Esto
//     preserva el histórico contable de cada cuenta intacto.
//   • Las transacciones NUNCA se borran. Para revertir, se crea una contra-
//     transacción enlazada por `anulaTransaccionId`. Los campos `anuladaAt` y
//     `anuladaPor` se setean en la transacción original al ser anulada.
//   • `paymentId` enlaza la transacción cuando fue generada automáticamente
//     al pagar una solicitud (egreso). 1:1 con Payment.
model Transaccion {
  id          String          @id @default(cuid())
  projectId   Int?
  programaId  Int?
  cuentaId    Int?            // snapshot — ver doc del modelo
  proyecto    String          // título legible del destino al momento del registro
  fecha       DateTime
  tipo        TipoTransaccion
  categoria   String
  descripcion String
  monto       Decimal         @db.Decimal(16, 2)
  moneda      Currency        @default(CRC)

  // Trazabilidad pago ↔ transacción
  paymentId   String?         @unique
  payment     Payment?        @relation(fields: [paymentId], references: [id])

  // Auditoría / anulación
  anuladaAt           DateTime?
  anuladaPor          Int?
  anulaTransaccionId  String?     @unique
  anulaTransaccion    Transaccion? @relation("AnulaTransaccion", fields: [anulaTransaccionId], references: [id])
  anuladaPorTx        Transaccion? @relation("AnulaTransaccion")

  createdAt   DateTime        @default(now())

  project   Project?              @relation(fields: [projectId], references: [id])
  programa  ProgramaVoluntariado? @relation(fields: [programaId], references: [id])
  cuenta    Cuenta?               @relation(fields: [cuentaId], references: [id])

  @@index([projectId, fecha, tipo])
  @@index([programaId, fecha, tipo])
  @@index([cuentaId, fecha])
}

model DocumentoContable {
  id        String   @id @default(cuid())
  projectId Int
  proyecto  String
  mes       Int
  anio      Int
  nombre    String
  tipoMime  String
  bytes     Int
  url       String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, anio, mes])
}

// ===== Facturación =====
enum Currency {
  CRC
  USD
  EUR
}

enum BillingRequestStatus {
  PENDING
  VALIDATED
  APPROVED
  REJECTED
  PAID
}

// ===== BillingRequest =====
// Ahora soporta tanto el flujo legacy (projectId/programaId) como el nuevo
// flujo basado en Área (areaId). `cuentaId` es snapshot al momento de creación.
model BillingRequest {
  id              Int                  @id @default(autoincrement())
  amount          Decimal              @db.Decimal(16, 2)
  concept         String
  projectId       Int?
  programaId      Int?
  // Nuevo flujo basado en Área
  areaId          Int?
  cuentaId        Int?
  status          BillingRequestStatus @default(PENDING)
  currency        String               @default("CRC")
  createdBy       String?
  draftInvoiceUrl String?
  history         Json?

  // 1:1 inversa (FK en BillingInvoice.requestId)
  invoice BillingInvoice?

  project  Project?              @relation(fields: [projectId], references: [id])
  programa ProgramaVoluntariado? @relation(fields: [programaId], references: [id])
  areaOrg  Area?                 @relation("AreaBillingRequests", fields: [areaId], references: [id])
  cuenta   Cuenta?               @relation(fields: [cuentaId], references: [id])
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([programaId])
  @@index([areaId])
  @@index([cuentaId])
}

model BillingInvoice {
  id        String   @id @default(cuid())
  requestId Int      @unique
  projectId Int
  number    String
  date      DateTime
  total     Decimal  @db.Decimal(16, 2)
  currency  Currency
  url       String?
  mime      String?
  bytes     Int?
  isValid   Boolean  @default(false)
  createdAt DateTime @default(now())

  request BillingRequest @relation(fields: [requestId], references: [id])
  project Project        @relation(fields: [projectId], references: [id])

  @@index([projectId, date])
}

model ProgramAllocation {
  id        String   @id @default(cuid())
  projectId Int
  concept   String
  amount    Decimal  @db.Decimal(16, 2)
  date      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, date])
}

// ===== Payment (polimorfo: Project XOR Programa) =====
// Heredan el destino del BillingRequest (no se acepta una mezcla incoherente).
// `cuentaId` es snapshot. Cada Payment genera 1 Transaccion de egreso vía
// el flujo transaccional del BillingService.
model Payment {
  id         String   @id @default(cuid())
  requestId  Int
  projectId  Int?
  programaId Int?
  cuentaId   Int?
  amount     Decimal  @db.Decimal(16, 2)
  currency   Currency
  reference  String
  date       DateTime

  // Comprobante de pago adjunto (PDF o imagen subida por el contador)
  comprobanteUrl String? @map("comprobante_url")
  comprobanteKey String? @map("comprobante_key") // clave en R2 para borrado

  project   Project?              @relation(fields: [projectId], references: [id])
  programa  ProgramaVoluntariado? @relation(fields: [programaId], references: [id])
  cuenta    Cuenta?               @relation(fields: [cuentaId], references: [id])
  request   BillingRequest        @relation(fields: [requestId], references: [id])
  receipts  Receipt[]
  // 1:1 con la Transaccion de egreso generada automáticamente.
  transaccion Transaccion?

  @@index([projectId, date])
  @@index([programaId, date])
  @@index([cuentaId, date])
}

model Receipt {
  id         String   @id @default(cuid())
  projectId  Int
  paymentId  String?
  url        String
  mime       String
  bytes      Int
  filename   String
  uploadedAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([projectId, uploadedAt])
}

model Auditoria {
  id         Int      @id @default(autoincrement())
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Identidad redundante: el usuario puede borrarse y aún así queremos saber quién actuó.
  userEmail  String?
  userName   String?

  // Acción legible: "SOLICITUD_CREAR", "PROYECTO_EDITAR", "VOLUNTARIO_SANCIONAR", etc.
  accion     String

  // Tipo de entidad afectada ("Solicitud", "Proyecto", "Voluntario", ...) e id (string para soportar cuid/int).
  entidad    String?
  entidadId  String?

  // Resumen humano del evento; ej.: "Aprobó solicitud #41 (₡250.000) para programa Reforestación".
  detalle    String?

  // Payload extra (estado anterior/nuevo, body sanitizado, etc.).
  metadata   Json?

  // Trazabilidad para auditorías de seguridad.
  ip         String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entidad, entidadId])
  @@index([accion])
}

enum CommentStatus {
  PENDIENTE
  APROBADO
  DENEGADO
}

model Comment {
  id            String        @id @default(cuid())
  author        String
  text          String
  status        CommentStatus @default(PENDIENTE)
  visible       Boolean       @default(false)
  attachmentUrl String?       @map("attachment_url")
  attachmentKey String?       @map("attachment_key")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum TipoFormulario {
  CONTACTO
  VOLUNTARIADO
  ALIANZA
  COMENTARIO
}

enum EstadoRespuestaFormulario {
  PENDIENTE
  ACEPTADO
  RECHAZADO
}

model RespuestaFormulario {
  id             String                    @id @default(uuid())
  tipoFormulario TipoFormulario
  nombre         String?
  correo         String?
  telefono       String?
  payload        Json
  estado         EstadoRespuestaFormulario @default(PENDIENTE)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@map("respuestas_formulario")
}

// ===== Visitacion — registro de visitas al parque / sede =====
model Visitacion {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @db.Date
  totalPersonas Int      @map("total_personas")
  nacionales    Int
  extranjeros   Int
  notas         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([fecha])
  @@map("visitacion")
}